# Database — Local development (SQLite)
DATABASE_URL="file:./dev.db"

# Database — Production (Supabase PostgreSQL)
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@[host].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[project-ref]:[password]@[host].supabase.com:5432/postgres"

# OpenAI API
OPENAI_API_KEY="sk-..."
# Set to false to pause AI analysis (news will still be fetched and stored)
ENABLE_AI=true

# Security — generate with: openssl rand -hex 32
CRON_SECRET="replace-with-random-secret"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
